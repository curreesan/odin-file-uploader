<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Odin File Uploader</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 40px; line-height: 1.6; }
    h1, h2 { color: #333; }
    .section { margin-bottom: 40px; padding: 20px; background: #f9f9f9; border-radius: 8px; }
    form { margin: 10px 0; }
    input, select, button {
      padding: 10px;
      margin: 5px 0;
      border: 1px solid #ccc;
      border-radius: 4px;
    }
    button {
      background: #007bff;
      color: white;
      cursor: pointer;
      border: none;
    }
    button:hover { background: #0056b3; }
    button.delete { background: #dc3545; }
    button.delete:hover { background: #c82333; }
    .file-list { margin-top: 15px; }
    .file-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px;
      border-bottom: 1px solid #eee;
    }
    .folder-header {
      background: #e9f7ef;
      padding: 10px;
      font-weight: bold;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <h1>Welcome, <%= currentUser?.name || currentUser?.email %>!</h1>
  <a href="/logout">Logout</a>
  <hr>

  <!-- Upload Section -->
  <div class="section">
    <h2>Upload New File</h2>
    <form action="/upload" method="POST" enctype="multipart/form-data">
      <input type="file" name="file" required><br><br>
      
      <label>Save to Folder:</label><br>
      <select name="folderId">
        <option value="">📁 Root (No Folder)</option>
        <% folders.forEach(folder => { %>
          <option value="<%= folder.id %>">📁 <%= folder.name %></option>
        <% }); %>
      </select>
      <br><br>
      <button type="submit">Upload File</button>
    </form>
  </div>

  <!-- Root Files -->
  <div class="section">
    <h2>Root Files</h2>
    <% if (rootFiles && rootFiles.length > 0) { %>
      <div class="file-list">
        <% rootFiles.forEach(file => { %>
          <div class="file-item">
            <div>
              <strong><%= file.originalName %></strong><br>
              <small><%= (file.size / 1024).toFixed(1) %> KB | <%= file.mimeType %></small>
            </div>
            <div>
              <a href="<%= file.url %>" target="_blank" download>Download</a>
              <form action="/files/<%= file.id %>/delete" method="POST" style="display:inline;">
                <button type="submit" class="delete" onclick="return confirm('Delete this file?')">Delete</button>
              </form>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <p>No files in root.</p>
    <% } %>
  </div>

  <!-- Files inside Folders -->
  <% folders.forEach(folder => { %>
    <div class="section">
      <div class="folder-header">
        📁 <%= folder.name %> 
        (<%= folder.files.length %> files)
        <form action="/folders/<%= folder.id %>/delete" method="POST" style="display:inline;">
          <button type="submit" class="delete" onclick="return confirm('Delete folder and all files inside?')">Delete Folder</button>
        </form>
      </div>

      <% if (folder.files && folder.files.length > 0) { %>
        <div class="file-list">
          <% folder.files.forEach(file => { %>
            <div class="file-item">
              <div>
                <strong><%= file.originalName %></strong><br>
                <small><%= (file.size / 1024).toFixed(1) %> KB | <%= file.mimeType %></small>
              </div>
              <div>
                <a href="<%= file.url %>" target="_blank" download>Download</a>
                <form action="/files/<%= file.id %>/delete" method="POST" style="display:inline;">
                  <button type="submit" class="delete" onclick="return confirm('Delete this file?')">Delete</button>
                </form>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <p>No files in this folder yet.</p>
      <% } %>
    </div>
  <% }); %>

</body>
</html>