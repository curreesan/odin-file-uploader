<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Dashboard - File Uploader</title>
</head>
<body>
  <h1>Dashboard</h1>
  
  <% if (currentUser) { %>
    <p>Welcome, <%= currentUser.name || currentUser.email %>!</p>

    <!-- Create New Folder -->
    <h2>Create New Folder</h2>
    <form action="/folders" method="POST">
      <input type="text" name="name" placeholder="Folder name" required>
      <button type="submit">Create Folder</button>
    </form>

    <hr>

    <!-- List of Folders -->
    <h2>Your Folders</h2>
    <% if (folders && folders.length > 0) { %>
      <ul>
        <% folders.forEach(folder => { %>
          <li>
            <%= folder.name %> 
            <small>(<%= folder.createdAt.toLocaleDateString() %>)</small>

            <form action="/folders/<%= folder.id %>/delete" method="POST" style="display: inline;">
                <button type="submit" onclick="return confirm('Delete folder <%= folder.name %> and all files inside it?')">
                    Delete
                </button>
            </form>
          </li>
        <% }); %>
      </ul>
    <% } else { %>
      <p>You don't have any folders yet.</p>
    <% } %>

    <br>
    <a href="/logout">Logout</a>
  <% } else { %>
    <p>Please <a href="/login">login</a>.</p>
  <% } %>
</body>
</html>